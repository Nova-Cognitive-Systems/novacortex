# ============================================
# NovaCortex — Unraid Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ── Ports ────────────────────────────────────
# Change if ports conflict with other Unraid containers
WEB_PORT=3000
API_PORT=3001

# ── Public URLs ──────────────────────────────
# Set to your Unraid server IP or domain (with port if no reverse proxy)
NEXT_PUBLIC_API_URL=http://192.168.1.100:3001
NEXT_PUBLIC_WS_URL=ws://192.168.1.100:3001
NEXTAUTH_URL=http://192.168.1.100:3000
CORS_ORIGINS=http://192.168.1.100:3000

# ── Secrets (CHANGE THESE!) ──────────────────
JWT_SECRET=change-this-to-a-long-random-string
NEXTAUTH_SECRET=change-this-to-a-long-random-string
REDIS_PASSWORD=change-this-redis-password

# ── SurrealDB ────────────────────────────────
SURREALDB_USER=root
SURREALDB_PASS=change-this-surrealdb-password
SURREALDB_NAMESPACE=novacortex
SURREALDB_DATABASE=production

# ── Qdrant ───────────────────────────────────
# Leave blank to disable Qdrant auth (fine for home/LAN use)
QDRANT_API_KEY=

# ── AI Keys (optional) ───────────────────────
# Required for semantic search / auto-embeddings
OPENAI_API_KEY=sk-...
# Optional — for future Anthropic integration
ANTHROPIC_API_KEY=

# ── Logging ──────────────────────────────────
LOG_LEVEL=info

# ── License ──────────────────────────────────
# Free tier (3 namespaces) — leave as-is
LICENSE_KEY=MS-FREE-mnskhsxz-117617dd-011fe479-A07B447D
