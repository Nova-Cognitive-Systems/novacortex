{
  "name": "@memory-stack/api",
  "version": "1.2.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./edge": {
      "import": "./dist/edge/index.js",
      "types": "./dist/edge/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:edge": "esbuild src/edge/worker.ts --bundle --format=esm --outfile=dist/edge/worker.js --platform=neutral --target=es2022 --conditions=worker --external:__STATIC_CONTENT_MANIFEST",
    "dev": "tsx watch src/index.ts",
    "dev:edge": "wrangler dev",
    "start": "node dist/index.js",
    "deploy:edge": "npm run build:edge && wrangler deploy",
    "deploy:edge:staging": "npm run build:edge && wrangler deploy --env staging",
    "deploy:edge:production": "npm run build:edge && wrangler deploy --env production",
    "test": "node --experimental-vm-modules ../../node_modules/vitest/vitest.mjs run",
    "test:edge": "node --experimental-vm-modules ../../node_modules/vitest/vitest.mjs run src/edge/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "tsc --noEmit -p tsconfig.edge.json"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@memory-stack/core": "*",
    "@opentelemetry/auto-instrumentations-node": "^0.55.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "pdf-parse": "1.1.1",
    "stripe": "^21.0.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260630.1",
    "@types/bcrypt": "^6.0.0",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
