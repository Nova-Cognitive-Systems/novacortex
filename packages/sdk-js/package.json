{
  "name": "@novacortex/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript/JavaScript SDK for NovaCortex \u2014 the self-hosted AI memory layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "novacortex",
    "ai",
    "memory",
    "agents",
    "vector-search",
    "mcp",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
