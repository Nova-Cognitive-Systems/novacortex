# ============================================
# NovaCortex SaaS - Production Environment
# ============================================
# SECURITY: Never commit this file to version control
# Copy to .env on production server and fill in values

# ============================================
# Domain Configuration
# ============================================
DOMAIN=novacortex.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# ============================================
# Database Credentials
# ============================================
# Generate strong passwords: openssl rand -base64 32
SURREALDB_USER=novacortex_admin
SURREALDB_PASS=CHANGE_ME_GENERATE_STRONG_PASSWORD
SURREALDB_NAMESPACE=novacortex
SURREALDB_DATABASE=production

REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
QDRANT_API_KEY=CHANGE_ME_GENERATE_STRONG_API_KEY

# ============================================
# Authentication Secrets
# ============================================
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_SECRET
JWT_EXPIRES_IN=7d

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32_CHAR_SECRET

# ============================================
# AI Providers
# ============================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=https://novacortex.yourdomain.com

# ============================================
# Cloudflare (if using DNS challenge)
# ============================================
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# ============================================
# Backups
# ============================================
S3_BUCKET=novacortex-backups
RETENTION_DAYS=30

# ============================================
# Monitoring
# ============================================
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ============================================
# Telemetry
# ============================================
NEXT_TELEMETRY_DISABLED=1
