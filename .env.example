# ============================================
# NovaCortex SaaS - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# Required variables are marked with [REQUIRED]

# ============================================
# Domain Configuration
# ============================================

# [REQUIRED] Primary domain for the application
DOMAIN=novacortex.example.com

# Email for Let's Encrypt SSL certificates
ACME_EMAIL=admin@example.com

# ============================================
# SurrealDB Configuration
# ============================================

# [REQUIRED] SurrealDB root credentials
SURREALDB_USER=root
SURREALDB_PASS=your-secure-surreal-password

# Database namespace and name
SURREALDB_NAMESPACE=novacortex
SURREALDB_DATABASE=production

# Connection URL (internal Docker network)
SURREALDB_URL=ws://surrealdb:8000/rpc

# ============================================
# Qdrant Configuration
# ============================================

# Qdrant connection (internal Docker network)
QDRANT_URL=http://qdrant:6333

# Optional: API key for Qdrant authentication
QDRANT_API_KEY=

# Vector configuration
QDRANT_COLLECTION=memories
QDRANT_VECTOR_SIZE=1536

# ============================================
# Redis Configuration
# ============================================

# [REQUIRED] Redis password
REDIS_PASSWORD=your-secure-redis-password

# Connection URL (constructed from password)
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ============================================
# Authentication
# ============================================

# [REQUIRED] JWT secret for API authentication
# Generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-minimum-32-characters

# JWT token expiration
JWT_EXPIRES_IN=7d

# [REQUIRED] NextAuth secret for session encryption
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-32-chars

# NextAuth URL (auto-configured from DOMAIN)
# NEXTAUTH_URL=https://${DOMAIN}

# ============================================
# AI Provider Configuration (Optional)
# ============================================

# OpenAI API key for embeddings
OPENAI_API_KEY=

# Anthropic API key (alternative)
ANTHROPIC_API_KEY=

# Default embedding model
EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# API Configuration
# ============================================

# Node environment
NODE_ENV=production

# API port (internal)
PORT=3001

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://${DOMAIN}

# ============================================
# Cloudflare (Optional - for DNS challenge)
# ============================================

# Required only if using Cloudflare DNS challenge for SSL
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# ============================================
# Backup Configuration (Optional)
# ============================================

# S3 bucket for remote backups
S3_BUCKET=

# Backup retention in days
RETENTION_DAYS=7

# ============================================
# Monitoring (Optional)
# ============================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Slack webhook for notifications
SLACK_WEBHOOK_URL=

# ============================================
# Feature Flags
# ============================================

# Enable debug features (development only)
DEBUG=

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1
